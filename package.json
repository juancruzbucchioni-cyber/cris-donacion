{
  "name": "cris-metal-escapes",
  "version": "0.1.0",
  "private": true,
  "description": "Catalogo web de Cris Metal Escapes para venta de escapes 4T de competicion en acero inoxidable.",
  "keywords": [
    "escapes",
    "motos",
    "cris-metal",
    "react",
    "typescript",
    "vite",
    "supabase",
    "tailwindcss"
  ],
  "author": "Danipa Bernales",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
